# Integration test credentials (copy to .env, do not commit .env)
# Used when running integration tests against localhost:4096
OPENCODE_SERVER_URL=http://localhost:4096
OPENCODE_USERNAME=your_username
OPENCODE_PASSWORD=your_password

# AI Builder speech recognition (for AIBuildersIntegrationTest)
AI_BUILDER_BASE_URL=https://your-ai-builder-instance.com
AI_BUILDER_TOKEN=your_ai_builder_token
